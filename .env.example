PORT=8787
HOST=127.0.0.1
SERVICE_BASE_URL=http://127.0.0.1:8787

# Optional API protection
CORTEX_API_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
CORTEX_MAX_BODY_SIZE=10mb

# OCR modes
# Leave CORTEX_OCR_PROVIDER empty to disable OCR.
# Supported values: ocr_space, generic_json
CORTEX_OCR_PROVIDER=
CORTEX_OCR_API_KEY=
CORTEX_OCR_PROVIDER_URL=
CORTEX_OCR_AUTH_HEADER=authorization
CORTEX_OCR_MODEL=
CORTEX_OCR_ENDPOINT=https://api.ocr.space/parse/image
CORTEX_OCR_LANGUAGE=eng
CORTEX_OCR_ENGINE=2
CORTEX_OCR_IS_TABLE=false
CORTEX_OCR_DETECT_ORIENTATION=true
CORTEX_OCR_SCALE=true

# x402 paid A2MCP mode
CORTEX_X402_ENABLED=false
CORTEX_X402_NETWORK=eip155:196
CORTEX_X402_PRICE=$0.01
CORTEX_X402_PAY_TO=
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=
